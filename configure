#!/bin/bash -e
# This is the ./configure script [1] for this project. It is responsible for
# configuring the local state of this particular folder. It will assume that
# the current environment is a fresh clone of this repository. It will also assume
# that the current environment is a Linux machine with the appropriate tools
# installed as specified in the .devcontainer/devcontainer.json file.
#
# 1. Install the devcontainers CLI [2].
# 2. Install Eleventy [3].
#
# [1]: https://en.wikipedia.org/wiki/Configure_script
# [2]: https://github.com/devcontainers/cli#readme
# [3]: https://www.11ty.dev/

# 1. Install the devcontainers CLI [2].
# 2. Install Eleventy [3].
npm i -g @devcontainers/cli @11ty/eleventy
